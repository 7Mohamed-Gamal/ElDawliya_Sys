  "features": [
    {
      "name": "Authentication & Authorization",
      "description": "User authentication, JWT tokens, API keys, role-based access control (RBAC)",
      "files": [
        "accounts/views.py",
        "accounts/models.py",
        "api/authentication.py",
        "api/permissions.py",
        "rbac/models.py"
      ],
      "api_doc": {
        "paths": {
          "/api/v1/auth/token/": {
            "post": {
              "summary": "Obtain JWT token pair",
              "tags": ["Authentication"],
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "username": {"type": "string"},
                        "password": {"type": "string"}
                      }
                    }
                  }
                }
              }
            }
          },
          "/api/v1/auth/token/refresh/": {
            "post": {
              "summary": "Refresh JWT access token",
              "tags": ["Authentication"]
            }
          }
        }
      }
    },
