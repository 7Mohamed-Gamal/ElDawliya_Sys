# ElDawliya System Environment Configuration
# ==========================================

# Django Core Settings
DJANGO_SECRET_KEY=django-insecure-development-key-change-in-production-123456789
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# Database Configuration (SQLite for development)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=

# For SQL Server (uncomment and configure if needed)
# DB_ENGINE=mssql
# DB_NAME=eldawliya_db
# DB_HOST=localhost
# DB_PORT=1433
# DB_USER=sa
# DB_PASSWORD=your_password
# DB_DRIVER=ODBC Driver 17 for SQL Server

# Cache Configuration
REDIS_URL=redis://127.0.0.1:6379/1
CACHE_TIMEOUT_MEDIUM=1800

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@eldawliya.com

# Security Configuration
FIELD_ENCRYPTION_KEY=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# API Configuration
API_RATE_LIMIT=100
API_THROTTLE_ANON=10/min
API_THROTTLE_USER=60/min
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Celery Configuration
CELERY_BROKER_URL=redis://127.0.0.1:6379/4
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/5

# Logging Configuration
LOG_DIR=logs
LOG_LEVEL=INFO

# HR System Settings
EMPLOYEE_NUMBER_PREFIX=EMP
EMPLOYEE_NUMBER_LENGTH=6
DEFAULT_WORK_HOURS_PER_DAY=8
DEFAULT_WORK_DAYS_PER_WEEK=5
OVERTIME_THRESHOLD_MINUTES=30
LATE_THRESHOLD_MINUTES=15
DOCUMENT_EXPIRY_WARNING_DAYS=30
LEAVE_BALANCE_CALCULATION_METHOD=monthly
PAYROLL_CALCULATION_METHOD=monthly
ATTENDANCE_SYNC_ENABLED=True
ATTENDANCE_SYNC_INTERVAL=300