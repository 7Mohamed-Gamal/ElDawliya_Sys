# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (SQL Server)
# -----------------------------------
# For Development (SQLite): Set DB_ENGINE=django.db.backends.sqlite3
# For Production (SQL Server): Set DB_ENGINE=mssql

DB_ENGINE=mssql
DB_NAME=ElDawliya_Sys
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUSTED=no

# Backup Database (Optional)
BACKUP_DB_NAME=ElDawliya_Sys_Backup
BACKUP_DB_HOST=localhost
BACKUP_DB_PORT=1433
BACKUP_DB_USER=sa
BACKUP_DB_PASSWORD=YourStrong@Passw0rd

# Redis
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/4
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/5

# Email (Production)
